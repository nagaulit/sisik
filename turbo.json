{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },

        "dev": {
            "persistent": true,
            "cache": false
        },

        "check": {
            "dependsOn": ["^check"],
            "outputs": []
        },

        "lint": {
            "dependsOn": ["^lint"],
            "outputs": []
        },

        "lint:fix": {
            "cache": false
        },

        "fmt": {
            "outputs": []
        },

        "fmt:check": {
            "outputs": []
        },

        "start": {
            "dependsOn": ["build"],
            "cache": false
        },

        "db:generate": {
            "cache": false
        },

        "db:migrate-dev": {
            "cache": false,
            "interactive": true
        },

        "db:migrate-reset": {
            "cache": false,
            "interactive": true
        },

        "db:studio": {
            "cache": false,
            "persistent": true
        }
    }
}
