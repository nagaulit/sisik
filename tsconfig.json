{
    "compilerOptions": {
        "strict": true,
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "baseUrl": ".",
        "paths": {
            "#env": ["src/config/env.util.ts"],
            "#config/*": ["src/config/*"],
            "#core/*": ["src/core/*"],
            "#common/*": ["src/common/*"],
            "#modules/*": ["src/modules/*"]
        }
    }
}
