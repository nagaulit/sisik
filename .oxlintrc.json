{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["typescript", "unicorn", "oxc"],
    "categories": {
        "correctness": "error"
    },
    "rules": {
        "typescript/consistent-type-imports": [
            "error",
            {
                "prefer": "type-imports"
            }
        ]
    },
    "env": {
        "builtin": true
    }
}
